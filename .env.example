# Porta do servidor
PORT=3000

# Caminho do executável Python (deixe em branco para usar 'python' do PATH)
# Exemplos: python, python3, C:/Python311/python.exe
PYTHON_BIN=python

# Pasta para arquivos enviados (relativa à raiz do projeto)
UPLOAD_DIR=storage/uploads

# Pasta para legendas geradas
OUTPUT_DIR=storage/outputs

# Tamanho máximo de upload em MB
MAX_UPLOAD_MB=500
